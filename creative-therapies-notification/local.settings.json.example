    "BLOB_CONTAINER_NAME": "<container name where the CSV is stored>",
    "BLOB_FILENAME": "<filename of the CSV, e.g. creative-therapies-data.csv>",

    "POWER_AUTOMATE_WEBHOOK_URL": "<Power Automate HTTP trigger URL>" 
  }
